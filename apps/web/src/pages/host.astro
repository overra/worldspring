---
// /host — the "host your own world" pitch (the landing nav's Host link). A static
// marketing page built on the shared Layout / "field manual" design system:
// near-black ground, olive accent, hairline borders, mono data readouts, sharp
// corners. Copy is the CURRENT survival framing only — self-host a configurable
// Worldspring server on your own Cloudflare account. The "fork it, make your own
// game" platform messaging is a separate pass and is deliberately NOT here. No SSR
// data loads: prerendered. The "DEPLOY — NEW WORLD" console is a decorative mock
// (illustration, not a live form).
import Layout from "../layouts/Layout.astro";

export const prerender = true;

// The mock deploy console in the hero — presentational only. Values echo the
// vocabulary the rest of the site already uses (deadcoast preset, 40 max/world).
const term = {
  fields: [
    { k: "region", v: "us-east" },
    { k: "preset", v: "deadcoast · balanced" },
  ],
  inline: [
    { k: "players", v: "40" },
    { k: "wipe", v: "monthly" },
  ],
};

// The three-step process (doc 00 self-host framing). Verbatim mock copy for 02/03.
const steps = [
  {
    n: "01",
    h: "Runs on your account",
    p: "Your world runs on your account, in your own Cloudflare — you own the data, the uptime, and the whole pennies-a-month bill. No game host to rent.",
  },
  {
    n: "02",
    h: "Pick a preset, name it",
    p: "Choose a personality and a wipe schedule, or tune the rules yourself.",
  },
  {
    n: "03",
    h: "Share the link",
    p: "It lists in the directory and heartbeats its status. Friends just click to join.",
  },
];
---

<Layout
  title="Host — run your own Worldspring island"
  description="Deploy your own Worldspring world on your Cloudflare account. Your rules, your wipe schedule, pennies a month — and it lists itself in the public directory."
  active="host"
>
  <section class="hero">
    <div class="wrap hero-inner">
      <div class="hero-copy">
        <p class="eyebrow">Host · Self-serve on Cloudflare</p>
        <h1>Host the island.<br />Your rules. Your own.</h1>
        <p class="lede">
          Deploy the world to your own Cloudflare account. Set your own wipe schedule. It
          heartbeats to the directory so friends can find it. No servers to babysit.
        </p>
        <div class="cta">
          <a class="btn primary" href="/servers/register">Deploy your world →</a>
          <a class="btn" href="/getting-started">Read the docs</a>
          <span class="mono note">pennies a month · your Cloudflare account</span>
        </div>
      </div>

      <div class="term" role="img" aria-label="Mock deploy console: deploying a new world to Cloudflare, then a live play.yourname.workers.dev link.">
        <div class="term-bar">
          <span class="term-title mono">Deploy — new world</span>
          <span class="term-dots" aria-hidden="true"><i></i><i></i><i class="on"></i></span>
        </div>
        <div class="term-body mono" aria-hidden="true">
          <div class="term-fields">
            {term.fields.map((f) => (
              <div class="tf"><span class="pair"><span class="k">{f.k}</span><span class="v">{f.v}</span></span></div>
            ))}
            <div class="tf">
              {term.inline.map((f) => (
                <span class="pair"><span class="k">{f.k}</span><span class="v">{f.v}</span></span>
              ))}
            </div>
          </div>
          <div class="term-out">
            <p class="line dim">&gt; deploying to your cloudflare…</p>
            <p class="line ok"><span class="chk">✓</span> live <span class="sep">·</span> <span class="url">play.yourname.workers.dev</span><span class="cursor"></span></p>
          </div>
        </div>
      </div>
    </div>
    <div class="topo" aria-hidden="true"></div>
  </section>

  <div class="wrap">
    <section class="block">
      <div class="sec-head">
        <span class="eyebrow">Stand up your own island</span>
        <h2>Three steps to your own world</h2>
      </div>
      <div class="steps">
        {steps.map((s) => (
          <article class="step">
            <span class="s-n mono">{s.n}</span>
            <h3>{s.h}</h3>
            <p>{s.p}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="block">
      <div class="cta-band">
        <div class="cb-copy">
          <span class="eyebrow">Ready when you are</span>
          <h2>Stand up your island</h2>
          <p class="cb-lede">Read the setup guide, or claim your listing in the directory and go live.</p>
        </div>
        <div class="cb-actions">
          <a class="btn primary" href="/servers/register">Deploy your world →</a>
          <a class="btn" href="/getting-started">Read the docs</a>
        </div>
      </div>
    </section>
  </div>
</Layout>

<style>
  /* ---- Hero: text + mock deploy console (mirrors index/about hero) ---- */
  .hero { position: relative; overflow: hidden; border-bottom: 1px solid var(--hairline); }
  .hero-inner {
    position: relative; z-index: 1; padding: 88px 28px 76px;
    display: grid; grid-template-columns: 1.05fr 0.95fr; gap: 52px; align-items: center;
  }
  .hero-copy { min-width: 0; }
  .hero h1 {
    font-weight: 700; font-size: clamp(34px, 5.2vw, 54px); line-height: 1.03;
    margin: 16px 0 0; text-wrap: balance;
  }
  .lede { max-width: 520px; margin: 22px 0 0; color: var(--ink-2); font-size: 17px; }
  .cta { display: flex; align-items: center; gap: 16px; flex-wrap: wrap; margin: 32px 0 0; }
  .cta .note { color: var(--ink-3); font-size: 12px; letter-spacing: 0.02em; }

  /* faint procedural-contour motif, right side of the hero (matches index/about) */
  .topo {
    position: absolute; inset: 0 -10% 0 40%; z-index: 0; pointer-events: none;
    background:
      radial-gradient(120% 100% at 100% 0%, rgba(125, 160, 107, 0.08), transparent 60%),
      repeating-radial-gradient(circle at 92% 30%, transparent 0 38px, rgba(125, 160, 107, 0.05) 38px 39px);
    mask-image: linear-gradient(90deg, transparent, #000 55%);
  }

  /* ---- Mock deploy console ---- */
  .term { border: 1px solid var(--hairline); background: var(--surface); min-width: 0; }
  .term-bar {
    display: flex; align-items: center; justify-content: space-between;
    padding: 10px 14px; border-bottom: 1px solid var(--hairline);
  }
  .term-title { font-size: 10px; letter-spacing: 0.22em; text-transform: uppercase; color: var(--ink-3); }
  .term-dots { display: flex; gap: 6px; }
  .term-dots i { width: 6px; height: 6px; border: 1px solid var(--hairline-2); display: block; }
  .term-dots i.on { background: var(--ink-3); border-color: var(--ink-3); }
  .term-body { padding: 18px 18px 20px; font-size: 13px; line-height: 1.85; }
  .term-fields {
    margin: 0 0 14px; padding: 0 0 14px; border-bottom: 1px solid var(--hairline);
    display: flex; flex-direction: column; gap: 6px;
  }
  .tf { display: flex; gap: 40px; flex-wrap: wrap; }
  .pair { display: flex; gap: 12px; }
  .k { color: var(--ink-3); min-width: 56px; }
  .v { color: var(--ink-body); }
  .term-out .line { margin: 0; }
  .line.dim { color: var(--ink-3); }
  .line.ok { color: var(--ink-body); margin-top: 4px; }
  .chk { color: var(--accent); }
  .sep { color: var(--ink-3); }
  .url { color: var(--accent-bright); }
  .cursor {
    display: inline-block; width: 7px; height: 14px; margin-left: 6px; vertical-align: -2px;
    background: var(--accent); animation: term-blink 1.1s steps(1) infinite;
  }
  @keyframes term-blink { 50% { opacity: 0; } }

  /* ---- Section scaffolding (matches about.astro) ---- */
  .block { margin: 72px 0 0; }
  .sec-head { margin: 0 0 26px; }
  .sec-head h2 { font-size: clamp(22px, 3vw, 27px); font-weight: 700; letter-spacing: 0.05em; margin: 10px 0 0; }

  /* ---- Numbered process ---- */
  .steps { display: grid; grid-template-columns: repeat(3, 1fr); border: 1px solid var(--hairline); }
  .step { padding: 24px 24px 28px; border-right: 1px solid var(--hairline); }
  .step:last-child { border-right: none; }
  .s-n { display: block; font-size: 12px; letter-spacing: 0.14em; color: var(--accent); }
  .step h3 { font-family: var(--font-display); text-transform: uppercase; font-size: 16px; font-weight: 600; letter-spacing: 0.06em; margin: 14px 0 0; color: var(--ink); }
  .step p { margin: 10px 0 0; color: var(--ink-2); font-size: 14.5px; }

  /* ---- Closing CTA band ---- */
  .cta-band {
    border: 1px solid var(--hairline); border-left: 2px solid var(--accent);
    padding: 28px 30px; display: flex; align-items: center; justify-content: space-between;
    gap: 30px; flex-wrap: wrap;
  }
  .cb-copy h2 { font-size: clamp(20px, 2.6vw, 25px); font-weight: 700; letter-spacing: 0.05em; margin: 10px 0 0; }
  .cb-lede { margin: 10px 0 0; color: var(--ink-2); font-size: 15px; max-width: 46ch; }
  .cb-actions { display: flex; gap: 14px; flex-wrap: wrap; }

  @media (prefers-reduced-motion: reduce) {
    .cursor { animation: none; }
  }
  @media (max-width: 900px) {
    .hero-inner { grid-template-columns: 1fr; gap: 40px; }
    .lede { max-width: 620px; }
  }
  @media (max-width: 820px) {
    .steps { grid-template-columns: 1fr; }
    .step { border-right: none; border-bottom: 1px solid var(--hairline); }
    .step:last-child { border-bottom: none; }
  }
  @media (max-width: 720px) {
    .hero-inner { padding: 60px 28px 52px; }
    .block { margin: 56px 0 0; }
    .cta-band { flex-direction: column; align-items: flex-start; }
  }
</style>
