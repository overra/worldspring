---
// /host — the "host your own world" pitch (the landing nav's Host link). A static
// marketing page built on the shared Layout / "field manual" design system:
// near-black ground, olive accent, hairline borders, mono data readouts, sharp
// corners. No SSR data loads: prerendered. The deploy card in the hero is a REAL
// call to action — every value it shows is a fact about what the button does, not a
// form being filled in; DEPLOY_URL is Cloudflare's hosted setup page, which clones
// the repo into the visitor's own GitHub and provisions the DO in their account.
// Nothing here may promise a choice the button does not offer (it asks for a repo
// name, a Worker name, and the .dev.vars.example secrets — no region, no preset, no
// wipe schedule; those are post-deploy config).
import Layout from "../layouts/Layout.astro";

export const prerender = true;

const REPO_URL = "https://github.com/overra/worldspring";
const DEPLOY_URL = `https://deploy.workers.cloudflare.com/?url=${REPO_URL}`;
const GUIDE_URL = `${REPO_URL}/blob/main/docs/SELF_HOSTING.md`;

// What the click actually gets you — read-outs, not inputs.
const spec = {
  fields: [
    { k: "source", v: "a fork, in your GitHub" },
    { k: "runs on", v: "your Cloudflare account" },
    { k: "url", v: "your-world.workers.dev" },
  ],
  inline: [
    { k: "cost", v: "pennies / month" },
    { k: "cli", v: "not required" },
  ],
};

const steps = [
  {
    n: "01",
    h: "Click deploy",
    p: "Cloudflare clones this repo into your own GitHub account and provisions the world — a Durable Object and its storage — in your own Cloudflare. You sign in to them, not to us.",
  },
  {
    n: "02",
    h: "It builds and goes live",
    p: "The build runs, the world deploys to your workers.dev subdomain, and your fork stays wired to it: every push you make redeploys your server.",
  },
  {
    n: "03",
    h: "Make it yours",
    p: "Pick a preset and tune the rules with one config var. Point a coding agent at the fork to change the game itself. Claim a directory listing so friends can find you.",
  },
];
---

<Layout
  title="Host — run your own Worldspring island"
  description="Deploy your own Worldspring world to your own Cloudflare account in one click. You get a source fork you can mod, your rules, and a pennies-a-month bill."
  active="host"
>
  <section class="hero">
    <div class="wrap hero-inner">
      <div class="hero-copy">
        <p class="eyebrow">Host · Self-serve on Cloudflare</p>
        <h1>Host the island.<br />Your rules. Your own.</h1>
        <p class="lede">
          One click puts a fork of the whole game in your GitHub and a running world in your
          Cloudflare account. Not a rented slot on our box — your source, your server, your
          bill. Mod it as far as you like.
        </p>
        <div class="cta">
          <a class="btn primary" href={DEPLOY_URL} target="_blank" rel="noopener">Deploy to Cloudflare →</a>
          <a class="btn" href={GUIDE_URL} target="_blank" rel="noopener">Setup guide</a>
          <span class="mono note">pennies a month · your Cloudflare account</span>
        </div>
      </div>

      <div class="term">
        <div class="term-bar">
          <span class="term-title mono">Deploy — new world</span>
          <span class="term-dots" aria-hidden="true"><i></i><i></i><i class="on"></i></span>
        </div>
        <div class="term-body mono">
          <div class="term-fields">
            {spec.fields.map((f) => (
              <div class="tf"><span class="pair"><span class="k">{f.k}</span><span class="v">{f.v}</span></span></div>
            ))}
            <div class="tf">
              {spec.inline.map((f) => (
                <span class="pair"><span class="k">{f.k}</span><span class="v">{f.v}</span></span>
              ))}
            </div>
          </div>
          <div class="term-cta">
            <a class="btn primary" href={DEPLOY_URL} target="_blank" rel="noopener">Deploy to Cloudflare →</a>
            <p class="line dim">Cloudflare asks for a repo name, a Worker name, and nothing else you don't have.</p>
          </div>
        </div>
      </div>
    </div>
    <div class="topo" aria-hidden="true"></div>
  </section>

  <div class="wrap">
    <section class="block">
      <div class="sec-head">
        <span class="eyebrow">Stand up your own island</span>
        <h2>Three steps to your own world</h2>
      </div>
      <div class="steps">
        {steps.map((s) => (
          <article class="step">
            <span class="s-n mono">{s.n}</span>
            <h3>{s.h}</h3>
            <p>{s.p}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="block">
      <div class="cta-band">
        <div class="cb-copy">
          <span class="eyebrow">Ready when you are</span>
          <h2>Stand up your island</h2>
          <p class="cb-lede">
            Deploy it in a click, or clone and run <code class="mono">wrangler deploy</code> yourself — the
            setup guide covers both, plus presets, directory listing, and modding the fork.
          </p>
        </div>
        <div class="cb-actions">
          <a class="btn primary" href={DEPLOY_URL} target="_blank" rel="noopener">Deploy to Cloudflare →</a>
          <a class="btn" href={GUIDE_URL} target="_blank" rel="noopener">Setup guide</a>
        </div>
      </div>
      <p class="post-note">
        Already deployed a server? <a href="/servers/register">Claim its listing</a> in the directory.
      </p>
    </section>
  </div>
</Layout>

<style>
  /* ---- Hero: text + deploy card (mirrors index/about hero) ---- */
  .hero { position: relative; overflow: hidden; border-bottom: 1px solid var(--hairline); }
  .hero-inner {
    position: relative; z-index: 1; padding: 88px 28px 76px;
    display: grid; grid-template-columns: 1.05fr 0.95fr; gap: 52px; align-items: center;
  }
  .hero-copy { min-width: 0; }
  .hero h1 {
    font-weight: 700; font-size: clamp(34px, 5.2vw, 54px); line-height: 1.03;
    margin: 16px 0 0; text-wrap: balance;
  }
  .lede { max-width: 520px; margin: 22px 0 0; color: var(--ink-2); font-size: 17px; }
  .cta { display: flex; align-items: center; gap: 16px; flex-wrap: wrap; margin: 32px 0 0; }
  .cta .note { color: var(--ink-3); font-size: 12px; letter-spacing: 0.02em; }

  /* faint procedural-contour motif, right side of the hero (matches index/about) */
  .topo {
    position: absolute; inset: 0 -10% 0 40%; z-index: 0; pointer-events: none;
    background:
      radial-gradient(120% 100% at 100% 0%, rgba(125, 160, 107, 0.08), transparent 60%),
      repeating-radial-gradient(circle at 92% 30%, transparent 0 38px, rgba(125, 160, 107, 0.05) 38px 39px);
    mask-image: linear-gradient(90deg, transparent, #000 55%);
  }

  /* ---- Deploy card ---- */
  .term { border: 1px solid var(--hairline); background: var(--surface); min-width: 0; }
  .term-bar {
    display: flex; align-items: center; justify-content: space-between;
    padding: 10px 14px; border-bottom: 1px solid var(--hairline);
  }
  .term-title { font-size: 10px; letter-spacing: 0.22em; text-transform: uppercase; color: var(--ink-3); }
  .term-dots { display: flex; gap: 6px; }
  .term-dots i { width: 6px; height: 6px; border: 1px solid var(--hairline-2); display: block; }
  .term-dots i.on { background: var(--ink-3); border-color: var(--ink-3); }
  .term-body { padding: 18px 18px 20px; font-size: 13px; line-height: 1.85; }
  .term-fields {
    margin: 0 0 16px; padding: 0 0 16px; border-bottom: 1px solid var(--hairline);
    display: flex; flex-direction: column; gap: 6px;
  }
  .tf { display: flex; gap: 40px; flex-wrap: wrap; }
  .pair { display: flex; gap: 12px; }
  .k { color: var(--ink-3); min-width: 56px; }
  .v { color: var(--ink-body); }
  .term-cta { display: flex; flex-direction: column; align-items: flex-start; gap: 12px; }
  .term-cta .btn { width: 100%; justify-content: center; }
  .term-cta .line { margin: 0; font-size: 11.5px; line-height: 1.6; }
  .line.dim { color: var(--ink-3); }

  /* ---- Section scaffolding (matches about.astro) ---- */
  .block { margin: 72px 0 0; }
  .sec-head { margin: 0 0 26px; }
  .sec-head h2 { font-size: clamp(22px, 3vw, 27px); font-weight: 700; letter-spacing: 0.05em; margin: 10px 0 0; }

  /* ---- Numbered process ---- */
  .steps { display: grid; grid-template-columns: repeat(3, 1fr); border: 1px solid var(--hairline); }
  .step { padding: 24px 24px 28px; border-right: 1px solid var(--hairline); }
  .step:last-child { border-right: none; }
  .s-n { display: block; font-size: 12px; letter-spacing: 0.14em; color: var(--accent); }
  .step h3 { font-family: var(--font-display); text-transform: uppercase; font-size: 16px; font-weight: 600; letter-spacing: 0.06em; margin: 14px 0 0; color: var(--ink); }
  .step p { margin: 10px 0 0; color: var(--ink-2); font-size: 14.5px; }

  /* ---- Closing CTA band ---- */
  .cta-band {
    border: 1px solid var(--hairline); border-left: 2px solid var(--accent);
    padding: 28px 30px; display: flex; align-items: center; justify-content: space-between;
    gap: 30px; flex-wrap: wrap;
  }
  .cb-copy h2 { font-size: clamp(20px, 2.6vw, 25px); font-weight: 700; letter-spacing: 0.05em; margin: 10px 0 0; }
  .cb-lede { margin: 10px 0 0; color: var(--ink-2); font-size: 15px; max-width: 52ch; }
  .cb-lede code { font-size: 13px; color: var(--ink-body); }
  .cb-actions { display: flex; gap: 14px; flex-wrap: wrap; }
  .post-note { margin: 14px 0 0; color: var(--ink-3); font-size: 13.5px; }

  @media (max-width: 900px) {
    .hero-inner { grid-template-columns: 1fr; gap: 40px; }
    .lede { max-width: 620px; }
  }
  @media (max-width: 820px) {
    .steps { grid-template-columns: 1fr; }
    .step { border-right: none; border-bottom: 1px solid var(--hairline); }
    .step:last-child { border-bottom: none; }
  }
  @media (max-width: 720px) {
    .hero-inner { padding: 60px 28px 52px; }
    .block { margin: 56px 0 0; }
    .cta-band { flex-direction: column; align-items: flex-start; }
  }
</style>
