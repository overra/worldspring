---
// /servers/:id — the shareable per-server detail page (doc 02 §8, M5). SSR:
// renders one live listing's full card from D1 (loadServerDetail →
// shapeServerDetail). A real 404 for unknown or non-`live` ids — the same
// no-existence-oracle posture as /join/:id and the report page (hidden, banned,
// pending, and unreachable rows are not browsable). NO server secrets
// (token_hash/challenge_hash/ip_hash) are selected, let alone rendered
// (doc 02 §7). All listing text is untrusted operator content; Astro {expr}
// auto-escapes it. Redesign (doc 00): rebuilt on the shared Layout / "field
// manual" design system — presentation only, the loader + 404 are untouched.
export const prerender = false;
import Layout from "../../../layouts/Layout.astro";
import { env } from "cloudflare:workers";
import { PROTOCOL_VERSION } from "@worldspring/shared/protocol";
import { GAME_VERSION } from "@worldspring/shared/version";
import { loadServerDetail } from "../../../lib/listing";

const db = (env as unknown as { DB: D1Database }).DB;
const now = Date.now();
const id = Astro.params.id ?? "";

let detail: Awaited<ReturnType<typeof loadServerDetail>> = null;
try {
  detail = await loadServerDetail(db, id, now, PROTOCOL_VERSION);
} catch (err) {
  // A D1 failure renders 404, same as /join and /report — never a 500 that
  // leaks a DB error, and no existence oracle for moderated rows.
  console.error("[servers/:id] detail lookup failed — rendering 404:", err);
}
if (!detail) {
  return new Response("Not found", { status: 404, headers: { "content-type": "text/plain" } });
}
const s = detail.view;

// Doc 02 §11: HTML cached 60 s. No per-visitor content on this page.
Astro.response.headers.set("cache-control", "public, max-age=60");

const isoDay = (ms: number): string => new Date(ms).toISOString().slice(0, 10);

/** Coarse "time since" for the last-probe honesty line (Factorio precedent). */
function ago(ms: number | null): string {
  if (ms === null) return "never";
  const s = Math.max(0, Math.floor((now - ms) / 1000));
  if (s < 60) return "just now";
  if (s < 3600) return `${Math.floor(s / 60)} min ago`;
  if (s < 86400) return `${Math.floor(s / 3600)} h ago`;
  return `${Math.floor(s / 86400)} d ago`;
}

// 20-day daily uptime strip (doc 02 §8): one cell per day, oldest → newest.
const todayDay = Math.floor(now / 86400_000);
const ratioByDay = new Map<number, number>();
for (const d of detail.dailyUptime) ratioByDay.set(d.day, d.ratio);
const strip = Array.from({ length: 20 }, (_, i) => {
  const day = todayDay - 19 + i;
  const ratio = ratioByDay.get(day);
  return { day, ratio: ratio ?? null };
});
// Health scale for the strip, mapped to design tokens where they exist. --gold
// is deliberately NOT used here (reserved for the Official marker); the two mid
// buckets use distinct amber/orange status hues instead.
function stripColor(ratio: number | null): string {
  if (ratio === null) return "var(--hairline-2)"; // no data
  if (ratio > 0.99) return "var(--accent)";
  if (ratio >= 0.5) return "#c68a34"; // degraded — amber (not the reserved gold)
  if (ratio > 0) return "#c15a2b"; // poor — burnt orange
  return "var(--danger)"; // down
}

const eyebrow = s.official ? "Official world" : "Community world";
---

<Layout
  title={`${s.name} — Worldspring server`}
  description={s.motd || `${s.name} — a community Worldspring server at ${s.host}`}
  active="servers"
>
  <main class={`detail wrap${s.official ? " is-official" : ""}`}>
    <div class="d-head">
      <div class="d-ident">
        <p class="eyebrow">{eyebrow}</p>
        <div class="d-name-row">
          <h1 class="d-name">{s.name}</h1>
          {s.official && <span class="tag gold">Official</span>}
          {s.outdated && (
            <span class="tag" title="runs an older version of Worldspring — content and fixes may be missing">outdated</span>
          )}
        </div>
        <p class="d-status mono">
          <span class={`dot ${s.activeNow ? "on" : "idle"}`}></span>
          {s.activeNow ? "Active now" : "Idle — wakes on join"} · {s.players}/{s.maxPlayers} players
        </p>
      </div>

      <div class="d-cta">
        {
          s.joinExternal ? (
            <a class="btn primary d-join" href={s.joinHref} target="_blank" rel="noopener noreferrer">
              Join {s.host} &rarr;
            </a>
          ) : (
            <a class="btn primary d-join" href={s.joinHref} data-server-id={s.id} data-join-url={s.joinUrl}>
              Join &rarr;
            </a>
          )
        }
        {!s.official && <a class="d-report mono" href={`/servers/${s.id}/report`}>Report this server</a>}
      </div>
    </div>

    {s.motd && <p class="d-motd">{s.motd}</p>}

    <div class="host-chip mono" title="server address">{s.host}</div>

    <dl class="spec">
      <div class="cell">
        <dt>Preset</dt>
        <dd class="mono">{s.preset}</dd>
      </div>

      <div class="cell">
        <dt>Version</dt>
        <dd class="mono">
          {s.version || "unknown"}
          {s.protocol !== null && <> · protocol {s.protocol}</>}
          {s.outdated && <span class="cell-note"> (latest {GAME_VERSION}, protocol {PROTOCOL_VERSION})</span>}
        </dd>
      </div>

      <div class="cell">
        <dt>Region</dt>
        <dd class="mono">
          {/* Compare case-insensitively: regionOf upper-cases an unmapped colo, so a
              stored lower/mixed-case code must not render twice as "ZZZ (zzz)". */}
          {s.region ?? "unknown"}{s.colo && s.region?.toUpperCase() !== s.colo.toUpperCase() ? ` (${s.colo})` : ""} ·
          {/* Default "—" (matches the list page): if JS is off / ping.js fails, this
              degrades honestly instead of a stuck "measuring…" that never resolves. */}
          {" "}<span class="ping" data-server-id={s.id} data-ping-url={s.joinUrl} data-pending="0">—</span>
        </dd>
      </div>

      <div class="cell">
        <dt>Listed since</dt>
        <dd class="mono">{isoDay(s.createdAt)}<span class="cell-note"> ({s.ageDays} {s.ageDays === 1 ? "day" : "days"})</span></dd>
      </div>

      <div class="cell">
        <dt>Last checked</dt>
        <dd class="mono">{ago(s.lastProbeAt)}</dd>
      </div>

      <div class="cell">
        <dt>Uptime (20d)</dt>
        <dd class="mono">{s.uptimePct === null ? "no probe data yet" : `${s.uptimePct}%`}</dd>
      </div>
    </dl>

    <section class="uptime">
      <div class="u-head">
        <span class="u-label">20-day daily uptime</span>
        <span class="u-avg mono">{s.uptimePct === null ? "no data" : `${s.uptimePct}% avg`}</span>
      </div>
      <div class="strip" title="probe uptime, one cell per day (oldest → newest)">
        {strip.map((c) => (
          <span
            style={`background:${stripColor(c.ratio)}`}
            title={`${isoDay(c.day * 86400_000)}: ${c.ratio === null ? "no data" : `${Math.round(c.ratio * 100)}%`}`}
          />
        ))}
      </div>
      <div class="u-scale mono">
        <span>20 days ago</span>
        <span>today</span>
      </div>
    </section>

    <p class="d-foot mono">
      <a href="/servers">&larr; All servers</a> · <a href="/policy/">Listing policy</a>
    </p>
  </main>

  <script src="/ping.js" defer is:inline></script>
</Layout>

<style>
  .detail { padding: 44px 28px 0; }
  .detail.is-official { border-left: 2px solid var(--gold); }

  /* ---- header: identity + join CTA ---- */
  .d-head { display: flex; align-items: flex-start; justify-content: space-between; gap: 28px; flex-wrap: wrap; }
  .d-ident { min-width: 0; flex: 1 1 auto; }
  .d-name-row { display: flex; align-items: center; gap: 12px; flex-wrap: wrap; margin: 10px 0 0; }
  .d-name {
    font-weight: 700; font-size: clamp(30px, 5vw, 46px); line-height: 1.04;
    letter-spacing: 0.02em; text-wrap: balance; word-break: break-word;
  }
  .d-status { color: var(--ink-2); font-size: 13px; margin: 14px 0 0; display: flex; align-items: center; gap: 9px; }

  .d-cta { display: flex; flex-direction: column; align-items: flex-end; gap: 10px; flex: none; padding-top: 4px; }
  .d-join { padding: 13px 24px; font-size: 14px; }
  .d-report { font-size: 11px; letter-spacing: 0.1em; text-transform: uppercase; color: var(--ink-3); }
  .d-report:hover { color: var(--danger); }

  .d-motd { color: var(--ink-body); font-size: 17px; max-width: 62ch; margin: 26px 0 0; }

  /* ---- host chip ---- */
  .host-chip {
    display: inline-block; margin: 26px 0 0; padding: 12px 18px;
    border: 1px solid var(--hairline-2); background: var(--surface);
    color: var(--ink); font-size: 15px; letter-spacing: 0.02em; word-break: break-all;
  }

  /* ---- spec grid (hairline cells over a hairline ground) ---- */
  .spec {
    display: grid; grid-template-columns: repeat(3, 1fr);
    gap: 1px; background: var(--hairline); border: 1px solid var(--hairline);
    margin: 32px 0 0;
  }
  .spec .cell { background: var(--bg); padding: 15px 18px 17px; min-width: 0; }
  .spec dt {
    font-family: var(--font-display); font-weight: 600; font-size: 10px;
    letter-spacing: 0.2em; text-transform: uppercase; color: var(--ink-3);
  }
  .spec dd { margin: 7px 0 0; color: var(--ink); font-size: 15px; line-height: 1.4; }
  .cell-note { color: var(--ink-3); }
  .ping { color: var(--ink-2); }

  /* ---- 20-day uptime strip ---- */
  .uptime { margin: 32px 0 0; border: 1px solid var(--hairline); padding: 16px 18px 18px; }
  .u-head { display: flex; align-items: baseline; justify-content: space-between; gap: 16px; }
  .u-label { font-family: var(--font-display); font-weight: 600; font-size: 10px; letter-spacing: 0.2em; text-transform: uppercase; color: var(--ink-3); }
  .u-avg { font-size: 12px; color: var(--accent); }
  .strip { display: flex; gap: 3px; margin-top: 12px; }
  .strip span { flex: 1 1 0; height: 30px; border: 1px solid rgba(0, 0, 0, 0.35); }
  .u-scale { display: flex; justify-content: space-between; margin-top: 8px; font-size: 10px; letter-spacing: 0.12em; text-transform: uppercase; color: var(--ink-3); }

  .d-foot { margin: 30px 0 0; font-size: 12px; color: var(--ink-3); }
  .d-foot a { color: var(--ink-2); }
  .d-foot a:hover { color: var(--ink); }

  /* ---- status dot + tags (page-local copies of the directory language) ---- */
  .dot { display: inline-block; width: 8px; height: 8px; border-radius: 50%; flex: none; }
  .dot.on { background: var(--accent); box-shadow: 0 0 6px rgba(125, 160, 107, 0.6); }
  .dot.idle { background: var(--ink-3); }
  .tag { font-family: var(--font-mono); font-size: 10px; letter-spacing: 0.06em; text-transform: uppercase; border: 1px solid var(--hairline-2); color: var(--ink-3); padding: 2px 7px; }
  .tag.gold { border-color: var(--gold); color: var(--gold); }

  @media (max-width: 760px) {
    .spec { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 620px) {
    .detail { padding: 32px 28px 0; }
    .d-cta { align-items: flex-start; width: 100%; }
    .spec { grid-template-columns: 1fr; }
  }
</style>
