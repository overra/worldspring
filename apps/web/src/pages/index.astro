// wins over Starlight's generated root, so the docs live at their own slugs.
// The real landing grows later; this scaffold proves the prerender path.
const title = "Worldspring";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} — host your own survival world</title>
  </head>
  <body>
    <main>
      <h1>{title}</h1>
      <p>A browser-native multiplayer survival sandbox — worlds you host and shape.</p>
      <p>
        <a href="/servers">Browse servers</a> · <a href="/getting-started">Docs</a>
      </p>
    </main>
  </body>
</html>
