{
  "name": "@worldspring/game",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": ">=22.6.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "typecheck": "tsc -p tsconfig.client.json --noEmit && tsc -p tsconfig.server.json --noEmit && tsc -p tsconfig.e2e.json --noEmit",
    "deploy": "vite build && wrangler deploy",
    "cf-typegen": "wrangler types",
    "models:export": "node scripts/export-models.mjs",
    "models:optimize-static": "node scripts/optimize-static-models.mjs",
    "models:icons": "node scripts/render-icons.mjs",
    "models:trees": "node scripts/generate-trees.mjs",
    "loadtest": "node --experimental-strip-types scripts/loadtest.mjs",
    "build-loadtest": "node --experimental-strip-types scripts/build-loadtest.mjs",
    "test": "pnpm test:persist && pnpm test:wipe && pnpm test:loot && pnpm test:tree-assets && pnpm test:destruction && pnpm test:trees && pnpm test:testbed && pnpm test:physics && pnpm test:vehicles && pnpm test:heartbeat && pnpm test:reload && pnpm test:wear && pnpm test:structures && pnpm test:terrain && pnpm test:dressing && pnpm test:snapcodec && pnpm test:arena && pnpm test:assets && pnpm test:wrangler",
    "test:persist": "node --experimental-strip-types scripts/persist-roundtrip.mjs",
    "test:wipe": "node --experimental-strip-types scripts/persist-wipe.mjs",
    "test:loot": "node --experimental-strip-types scripts/loot-invariant.mjs",
    "test:tree-assets": "node scripts/generate-trees.mjs --check",
    "test:destruction": "node --experimental-strip-types scripts/destruction-probe.mjs",
    "test:trees": "node --experimental-strip-types scripts/trees.mjs",
    "test:testbed": "node --experimental-strip-types scripts/testbed-provision.mjs",
    "test:physics": "node --experimental-strip-types scripts/physics-replay.mjs",
    "test:vehicles": "node --experimental-strip-types scripts/vehicles-smoke.mjs",
    "test:heartbeat": "node --experimental-strip-types scripts/heartbeat-cadence.mjs",
    "test:reload": "node --experimental-strip-types scripts/reload-magazine.mjs",
    "test:wear": "node --experimental-strip-types scripts/wear-slots.mjs",
    "test:structures": "node --experimental-strip-types scripts/structures.mjs",
    "test:terrain": "node --experimental-strip-types scripts/terrain-chunks.mjs",
    "test:dressing": "node --experimental-strip-types scripts/chunked-dressing.mjs",
    "test:snapcodec": "node --experimental-strip-types scripts/snap-codec.mjs",
    "test:arena": "node --experimental-strip-types scripts/arena-probe.mjs",
    "test:assets": "node scripts/asset-fingerprint.mjs",
    "test:wrangler": "node scripts/wrangler-parity.mjs",
    "assets:fingerprint": "node scripts/asset-fingerprint.mjs",
    "test:e2e": "vite build && playwright test -c e2e/playwright.config.ts",
    "test:e2e:update": "vite build && playwright test -c e2e/playwright.config.ts --update-snapshots"
  },
  "dependencies": {
    "@dgreenheck/three-pinata": "2.0.1",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "@react-three/postprocessing": "^3.0.4",
    "@worldspring/shared": "workspace:*",
    "n8ao": "^1.10.1",
    "postprocessing": "^6.39.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "three": "^0.184.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.40.1",
    "@playwright/test": "^1.61.0",
    "@types/node": "^22.10.2",
    "@dgreenheck/ez-tree": "1.1.0",
    "@dimforge/rapier3d-compat": "^0.19.3",
    "@gltf-transform/cli": "4.4.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.184.1",
    "@vitejs/plugin-react": "^6.0.2",
    "typescript": "catalog:",
    "vite": "^8.0.16",
    "wrangler": "catalog:"
  }
}
