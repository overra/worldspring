{
  "name": "@worldspring/game",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "typecheck": "tsc -p tsconfig.client.json --noEmit && tsc -p tsconfig.server.json --noEmit",
    "deploy": "vite build && wrangler deploy",
    "cf-typegen": "wrangler types",
    "loadtest": "node scripts/loadtest.mjs",
    "test": "pnpm test:persist && pnpm test:wipe && pnpm test:loot",
    "test:persist": "node --experimental-strip-types scripts/persist-roundtrip.mjs",
    "test:wipe": "node --experimental-strip-types scripts/persist-wipe.mjs",
    "test:loot": "node --experimental-strip-types scripts/loot-invariant.mjs"
  },
  "dependencies": {
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "@react-three/postprocessing": "^3.0.4",
    "@worldspring/shared": "workspace:*",
    "n8ao": "^1.10.1",
    "postprocessing": "^6.39.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "three": "^0.184.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.40.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.184.1",
    "@vitejs/plugin-react": "^6.0.2",
    "typescript": "catalog:",
    "vite": "^8.0.16",
    "wrangler": "catalog:"
  }
}
